[
    {
        "output": "eDP-1",
        "layer": "top",
        "position": "top",
        "height": 24,
        "spacing": 0,

        "modules-left": [
            "sway/workspaces",
            "sway/mode",
            "sway/window"
        ],
        "modules-center": ["clock"],
        "modules-right": [
            "custom/pacman",
            "network#wifi",
            "disk",
            "memory",
            "cpu",
            "temperature",
            "sway/language",
            "pulseaudio",
            "battery",
            "power-profiles-daemon",
            "tray"
        ],

        "sway/workspaces": {
            "disable-scroll": true,
            "all-outputs": true,
            "format": "{name}",
            "strip-workspace-numbers": true
        },

        "sway/mode": {
            "format": " {} "
        },

        "sway/window": {
            "max-length": 50
        },

        "clock": {
            "format": "{:%d/%m %H:%M:%S}",
            "interval": 1,
            "tooltip-format": "{:%A, %B %d, %Y}"
        },

        "sway/language": {
            "format": "\uf11c {short}",
            "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
        },

        "cpu": {
            "format": "\uf2db {usage}%",
            "interval": 2,
            "states": {
                "warning": 75,
                "critical": 90
            }
        },

        "memory": {
            "format": "\uf538 {percentage}%",
            "interval": 2,
            "states": {
                "warning": 50,
                "critical": 90
            }
        },

        "temperature": {
            "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
            "format": "\uf2cb {temperatureC}°C",
            "critical-threshold": 80,
            "warning-threshold": 60
        },

        "disk": {
            "path": "/",
            "format": "\uf1c0 {percentage_used}%",
            "states": {
                "warning": 90,
                "critical": 95
            }
        },

        "pulseaudio": {
            "signal": 1,
            "format": "\uf027 {volume}%",
            "format-muted": "\uf6a9",
            "on-click": "vol-pipewire.sh toggle",
            "on-scroll-up": "vol-pipewire.sh + 5",
            "on-scroll-down": "vol-pipewire.sh - 5"
        },

        "network#wifi": {
            "interface": "wlp1s0",
            "format-wifi": "\uf1eb  {essid} {signalStrength}%",
            "format-disconnected": "\uf1eb  -",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid} ({signalStrength}%)"
        },

        "custom/pacman": {
            "exec": "checkupdates 2>/dev/null | wc -l",
            "interval": 3600,
            "format": "\uf1b3 {}",
            "exec-if": "checkupdates 2>/dev/null | grep -q ."
        },

        "power-profiles-daemon": {
            "format": "{icon}",
            "tooltip-format": "Profile: {profile}",
            "format-icons": {
                "default": "\uf0e7",
                "performance": "\uf0e7",
                "balanced": "\uf24e",
                "power-saver": "\uf06c"
            }
        },

        "battery": {
            "bat": "BAT0",
            "interval": 30,

            "states": {
                "warning": 25,
                "critical": 10
            },

            "format": "\uf242 {capacity}%",
            "format-full": "\uf240 {capacity}%",
            "format-warning": "\uf244 {capacity}%",
            "format-critical": "\uf244 {capacity}%",
            "format-charging": "\uf1e6 {capacity}%",
            "format-plugged": "\uf1e6 {capacity}%",

            "tooltip-format": "{timeTo} ({power}W)"
        },

        "tray": {
            "icon-size": 16,
            "spacing": 8
        }
    }
]
